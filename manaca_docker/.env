# compose.yml内で利用する環境変数の設定
COMPOSE_PROJECT_NAME=manaca_docker
CONTAINER_NAME=manaca_checker

Dockerfile_DIR=.
Dockerfile=Dockerfile

VOLUME=./linux_data

TIME_ZONE=Asia/Tokyo
LANG=ja_JP.UTF8

PORT=3000

USER_NAME=PEN
PASSWORD=password

ENTRY_DIR=Programs
ENTRY_POINT=start.sh

WS=WS

# host.sh が参照する実行環境の種別
# linux   : Raspberry Pi 等のネイティブLinuxホスト (デフォルト)
# windows : Windows + Docker Desktop (WSL2) ホスト
PLATFORM=linux