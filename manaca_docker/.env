# compose.yml内で利用する環境変数の設定
COMPOSE_PROJECT_NAME=manaca_docker
CONTAINER_NAME=manaca_checker

Dockerfile_DIR=.
Dockerfile=Dockerfile

VOLUME=./linux_data

TIME_ZONE=Asia/Tokyo
LANG=ja_JP.UTF8

NETWORK_NAME=ethd
IP_SUBNET_ADDR=192.168.10.0
IP_PREFIX=24
IP_GATEWAY_ADDR=192.168.10.1

PORT=3000

USER_NAME=PEN
PASSWORD=password

ENTRY_DIR=Programs
ENTRY_POINT=start.sh

WS=WS

# GPIOデバイス。 `gpiodetect` を実行し、"pinctrl-rp1" と表示された
# gpiochipの番号を確認して合わせること (Pi5でも機種/カーネルにより番号が変わる。
# `ls /dev/gpio*` だけではどれが40ピンヘッダかまでは分からないので注意)
GPIOMEM=/dev/gpiomem0
GPIOCHIP=/dev/gpiochip0