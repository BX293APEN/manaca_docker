# compose.yml内で利用する環境変数の設定
COMPOSE_PROJECT_NAME=project1           # プロジェクト名(全て小文字)
CONTAINER_NAME=Docker_Linux

Dockerfile_DIR=.
Dockerfile=Dockerfile

VOLUME=./linux_data

TIME_ZONE=Asia/Tokyo
LANG=ja_JP.UTF8

NETWORK_NAME=ethd
IP_SUBNET_ADDR=192.168.10.0
IP_PREFIX=24
IP_GATEWAY_ADDR=192.168.10.1

PORT=3000

USER_NAME=PEN
PASSWORD=password

ENTRY_DIR=Programs
ENTRY_POINT=start.py

WS=WS